# Alpaca (real-time US stock prices — free tier, alpaca.markets)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# System
LOG_LEVEL=INFO
PAPER_TRADE_ONLY=true
# Auto-fill an empty dashboard with recent posts on first run without firing stale trades.
BACKFILL_ON_START=
